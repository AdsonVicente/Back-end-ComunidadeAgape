generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evento {
  id         String      @id @db.Uuid
  titulo     String      @db.VarChar(100)
  descricao  String
  local      String      @db.VarChar(50)
  data       DateTime
  horario    String      @db.VarChar(8)
  banner     String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  inscricoes Inscricao[]

  @@map("eventos")
}

model Conteudo {
  id           String    @id @db.Uuid
  titulo       String    @db.VarChar(100)
  descricao    String
  autor        String
  banner       String    @db.VarChar(255)
  publicadoEm  DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  categoria    String    @db.Uuid
  viewCount    Int       @default(0)
  category     Categoria @relation(fields: [categoria], references: [id])

  @@map("conteudos")
}

model Administrador {
  id        String   @id @db.Uuid
  nome      String   @db.VarChar(50)
  email     String   @unique
  senha     String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("administradores")
}

model Liturgia {
  id                String   @id @db.Uuid
  data              DateTime @default(now())
  titulo            String
  corLiturgica      String
  primeiraLeitura   String
  salmoResponsorial String
  segundaLeitura    String?
  evangelho         String
  dia               DateTime @unique @db.Date

  @@map("liturgias")
}

model Categoria {
  id        String     @id @db.Uuid
  nome      String     @unique
  data      DateTime   @default(now())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  Conteudos Conteudo[]

  @@map("categorias")
}

model Inscricao {
  id        String   @id @db.Uuid
  nome      String
  telefone  String
  idade     Int
  email     String
  grupo     String?
  setor     String?
  createdAt DateTime @default(now())
  eventId   String   @db.Uuid
  evento    Evento   @relation(fields: [eventId], references: [id])

  @@map("Inscricoes")
}

model Contato {
  id       String   @id @default(uuid())
  nome     String
  assunto  String
  mensagem String
  criadoEm DateTime @default(now())
  email    String
  telefone String
}
